# ============================================================
# EFG Learning — Variables d'environnement PRODUCTION
# ============================================================
# Copier ce fichier vers .env et remplir toutes les valeurs.
# Ne jamais committer le .env réel dans git.
# ============================================================

# Clé secrète Django — générer avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=remplacer-par-une-vraie-cle-secrete-longue-et-aleatoire

# Désactiver le mode debug en production (obligatoire)
DEBUG=False

# Domaines autorisés à servir l'application
# Inclure le domaine principal et www si applicable
ALLOWED_HOSTS=efg-learning.com,www.efg-learning.com

# ── Base de données PostgreSQL ────────────────────────────────────────────────
# Format : postgres://utilisateur:mot_de_passe@hote:port/nom_base
# Exemples :
#   Local          : postgres://efguser:motdepasse@localhost:5432/efglearning
#   Render         : postgres://user:pass@dpg-xxx.oregon-postgres.render.com/efglearning
#   Supabase       : postgres://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgres://efguser:motdepasse@localhost:5432/efglearning

# ── CORS — origines Flutter autorisées ───────────────────────────────────────
# Adresses depuis lesquelles Flutter Web peut appeler l'API
# Laisser vide si l'application est mobile uniquement (pas de Flutter Web)
CORS_ALLOWED_ORIGINS=https://efg-learning.com,https://www.efg-learning.com

# ── CSRF — origines autorisées pour le panneau /admin/ ───────────────────────
# Doit correspondre exactement aux URLs depuis lesquelles le navigateur accède à /admin/
CSRF_TRUSTED_ORIGINS=https://efg-learning.com,https://www.efg-learning.com
